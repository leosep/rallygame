@page "/Game/Reglas"
@{
    Layout = "_GameLayout";
}

<div class="max-w-lg mx-auto">
    <div class="bg-white rounded-2xl shadow-xl p-6">
        <h1 class="text-2xl font-bold text-gray-800 mb-6">Reglas del Rally</h1>
        
        <div class="space-y-4 text-gray-600">
            <div class="flex gap-4">
                <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-blue-600 font-bold">1</span>
                </div>
                <div>
                    <h3 class="font-semibold text-gray-800">Regístrate</h3>
                    <p class="text-sm">Ingresa tu nombre para obtener un token único</p>
                </div>
            </div>
            
            <div class="flex gap-4">
                <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-blue-600 font-bold">2</span>
                </div>
                <div>
                    <h3 class="font-semibold text-gray-800">Escanea</h3>
                    <p class="text-sm">Busca los códigos QR en las estaciones del rally</p>
                </div>
            </div>
            
            <div class="flex gap-4">
                <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-blue-600 font-bold">3</span>
                </div>
                <div>
                    <h3 class="font-semibold text-gray-800">Responde</h3>
                    <p class="text-sm">Selecciona la respuesta correcta para cada pregunta</p>
                </div>
            </div>
            
            <div class="flex gap-4">
                <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-blue-600 font-bold">4</span>
                </div>
                <div>
                    <h3 class="font-semibold text-gray-800">Gana</h3>
                    <p class="text-sm">Entre más正确答案越多,越好 tu posición en el ranking</p>
                </div>
            </div>
        </div>
        
        <a href="/" class="block mt-8 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded-lg transition-colors">
            ¡Comenzar Ahora!
        </a>
    </div>
</div>