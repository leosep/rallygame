@page "/Game/Sobre"
@{
    Layout = "_GameLayout";
}

<div class="max-w-lg mx-auto">
    <div class="bg-white rounded-2xl shadow-xl p-6">
        <h1 class="text-2xl font-bold text-gray-800 mb-6">Sobre el Rally</h1>
        
        <div class="prose text-gray-600">
            <p class="mb-4">
                Te invitamos a participar 
                en este rally tecnológico interactivo.
            </p>
            <p class="mb-4">
                Durante el evento, recorrido las diferentes estaciones escaneando códigos QR que te 
                presentarán preguntas.
            </p>
            <p>
                ¡Pon a prueba tus conocimientos y很远排名 en el leaderboard!
            </p>
        </div>
        
        <div class="mt-8 border-t pt-6">
            <h2 class="font-semibold text-gray-800 mb-3">Contacto</h2>
            <p class="text-sm text-gray-500">
                <i class="fas fa-envelope mr-2"></i>info@fun.gob.do<br>
                <i class="fas fa-phone mr-2"></i>+1 (809) 732-1000<br>
                <i class="fas fa-globe mr-2"></i>www.fun.gob.do
            </p>
        </div>
        
        <a href="/" class="block mt-8 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded-lg transition-colors">
            ¡Participar Ahora!
        </a>
    </div>
</div>