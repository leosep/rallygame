<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rally Fun</title>
    <link rel="stylesheet" href="~/css/tailwind.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family: 'Poppins', sans-serif; }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-blue-600 via-purple-600 to-indigo-700 min-h-screen" oncontextmenu="return false" onselectstart="return false" ondragstart="return false" oncopy="return false" oncut="return false">
    <div class="min-h-screen p-4 md:p-8">
        @RenderBody()
    </div>
    
    <!-- Anti-cheat overlay -->
    <div id="cheat-overlay" class="fixed inset-0 bg-black bg-opacity-90 flex items-center justify-center z-[9999] hidden">
        <div class="text-center text-white p-8">
            <i class="fas fa-exclamation-triangle text-5xl text-yellow-500 mb-4"></i>
            <h2 class="text-2xl font-bold mb-2">¡Espera!</h2>
            <p class="text-gray-300">No puedes salir de la página mientras respondes una pregunta.</p>
            <button onclick="document.getElementById('cheat-overlay').classList.add('hidden')" class="mt-6 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg">
                Volver al juego
            </button>
        </div>
    </div>
    
    <script>
        let lastActiveTime = Date.now();
        
        document.addEventListener('visibilitychange', function() {
            const app = document.getElementById('app');
            if (!app || !app.__vue_app__) return;
            
            const vueData = app.__vue_app__._instance.proxy;
            if (document.hidden && vueData.currentStep === 'question') {
                document.getElementById('cheat-overlay').classList.remove('hidden');
            }
            lastActiveTime = Date.now();
        });
        
        setInterval(() => {
            const app = document.getElementById('app');
            if (!app || !app.__vue_app__) return;
            
            const vueData = app.__vue_app__._instance.proxy;
            if (vueData.currentStep === 'question' && vueData.tiempoRestante <= 0) {
                document.getElementById('cheat-overlay').classList.remove('hidden');
            }
        }, 1000);
    </script>
    
    <!-- Mobile bottom nav -->
    <nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 md:hidden z-50">
        <div class="flex justify-around py-3">
            <a href="/" class="text-gray-500 hover:text-blue-600 transition-colors">
                <i class="fas fa-home text-xl"></i>
            </a>
            <a href="/Game/Reglas" class="text-gray-500 hover:text-blue-600 transition-colors">
                <i class="fas fa-question-circle text-xl"></i>
            </a>
            <a href="/Game/Sobre" class="text-gray-500 hover:text-blue-600 transition-colors">
                <i class="fas fa-info-circle text-xl"></i>
            </a>
            <a href="/Admin/Login" class="text-gray-500 hover:text-blue-600 transition-colors">
                <i class="fas fa-cog text-xl"></i>
            </a>
        </div>
    </nav>
    
    <div class="pb-16 md:pb-0"></div>
</body>
</html>