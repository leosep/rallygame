<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Rally Fun</title>
    <link rel="stylesheet" href="~/css/tailwind.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-gray-50">
    <div class="flex min-h-screen">
        <aside class="w-64 bg-slate-900 text-white hidden md:flex flex-col fixed h-full z-30">
            <div class="p-6 border-b border-slate-800">
                <h1 class="text-xl font-bold">Rally Fun</h1>
                <p class="text-xs text-slate-400">Panel Admin</p>
            </div>
            
            <nav class="flex-1 px-4 py-4 space-y-1">
                <a href="/Admin/Dashboard" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors @(Context.Request.Path.Value?.Contains("/Admin/Dashboard") == true ? "bg-slate-800" : "")">
                    <i class="fas fa-chart-line w-5"></i>Dashboard
                </a>
                <a href="/Admin/Participantes" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors @(Context.Request.Path.Value?.Contains("/Admin/Participantes") == true ? "bg-slate-800" : "")">
                    <i class="fas fa-users w-5"></i>Participantes
                </a>
                <a href="/Admin/Preguntas" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors @(Context.Request.Path.Value?.Contains("/Admin/Preguntas") == true ? "bg-slate-800" : "")">
                    <i class="fas fa-question-circle w-5"></i>Preguntas
                </a>
                <a href="/Admin/Respuestas" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors @(Context.Request.Path.Value?.Contains("/Admin/Respuestas") == true ? "bg-slate-800" : "")">
                    <i class="fas fa-check-circle w-5"></i>Respuestas
                </a>
                <a href="/Admin/Codigos" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors @(Context.Request.Path.Value?.Contains("/Admin/Codigos") == true ? "bg-slate-800" : "")">
                    <i class="fas fa-qrcode w-5"></i>Códigos QR
                </a>
            </nav>

            <div class="p-4 border-t border-slate-800">
                <a href="/Admin/Logout" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors text-red-400">
                    <i class="fas fa-sign-out-alt w-5"></i>Cerrar Sesión
                </a>
            </div>
        </aside>

        <main class="flex-1 md:ml-64 p-4 md:p-8">
            @RenderBody()
        </main>
    </div>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>