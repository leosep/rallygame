@page
@model rallygame.Web.Pages.Admin.PreguntasModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Preguntas";
}

<div class="mb-8 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Preguntas</h1>
        <p class="text-gray-500">Gestión de preguntas del rally</p>
    </div>
    <a href="/Admin/Preguntas/Create" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition-colors">
        <i class="fas fa-plus mr-2"></i>Nueva Pregunta
    </a>
</div>

<div class="space-y-4">
    @for (int i = 0; i < Model.Preguntas.Count; i++)
    {
        var p = Model.Preguntas[i];
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-start justify-between">
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-2">
                        <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium">Q@(i + 1)</span>
                        @if (p.Activa)
                        {
                            <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Activa</span>
                        }
                        else
                        {
                            <span class="bg-gray-100 text-gray-600 px-2 py-1 rounded text-xs">Inactiva</span>
                        }
                    </div>
                    <h3 class="text-lg font-semibold text-gray-800">@p.Pregunta1</h3>
                    <p class="text-sm text-gray-500 mt-1">Código: <code class="bg-gray-100 px-1 rounded">@p.CodigoAlt</code></p>
                </div>
                <div class="flex gap-2">
                    <a href="/Admin/Preguntas/Edit/@p.Id" class="p-2 text-gray-500 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">
                        <i class="fas fa-edit"></i>
                    </a>
                    <button onclick="eliminarPregunta(@p.Id, '@Html.Raw(System.Web.HttpUtility.HtmlEncode(p.Pregunta1))')" class="p-2 text-gray-500 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </div>
            
            @if (p.Opcions.Any())
            {
                <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
                    @foreach (var op in p.Opcions)
                    {
                        <div class="flex items-center gap-3 p-3 rounded-lg @(op.Correcto ? "bg-green-50 border border-green-200" : "bg-gray-50")">
                            @if (op.Correcto)
                            {
                                <i class="fas fa-check-circle text-green-500"></i>
                            }
                            <span class="@(op.Correcto ? "text-green-700 font-medium" : "text-gray-600")">@op.Respuesta</span>
                        </div>
                    }
                </div>
            }
        </div>
    }
    
    @if (!Model.Preguntas.Any())
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 text-center">
            <i class="fas fa-question-circle text-4xl mb-4 text-gray-300"></i>
            <p class="text-gray-500">No hay preguntas configuradas</p>
            <a href="/Admin/Preguntas/Create" class="text-blue-600 hover:text-blue-700 mt-2 inline-block">Crear primera pregunta</a>
        </div>
    }
</div>

<script>
    async function eliminarPregunta(id, nombre) {
        if (!confirm('¿Eliminar la pregunta "' + nombre + '"? Esto también eliminará sus respuestas.')) {
            return;
        }
        
        try {
            const response = await fetch('/api/admin/pregunta/' + id, { 
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await response.json();
            if (response.ok) {
                location.reload();
            } else {
                alert(data.error || 'Error al eliminar la pregunta');
            }
        } catch (e) {
            alert('Error al eliminar la pregunta');
        }
    }
</script>
