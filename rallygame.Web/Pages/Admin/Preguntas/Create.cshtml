@page
@model rallygame.Web.Pages.Admin.CreatePreguntaModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Nueva Pregunta";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a href="/Admin/Preguntas" class="text-blue-600 hover:text-blue-700">
            <i class="fas fa-arrow-left mr-2"></i>Volver a Preguntas
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h1 class="text-2xl font-bold text-gray-800 mb-6">Nueva Pregunta</h1>

        <form method="post">
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Pregunta <span class="text-red-500">*</span></label>
                    <textarea asp-for="Pregunta1" rows="3" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"></textarea>
                    <span asp-validation-for="Pregunta1" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Código Alternativo (QR)</label>
                    <input asp-for="CodigoAlt" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                </div>

                <div>
                    <label class="flex items-center gap-2">
                        <input asp-for="Activa" type="checkbox" class="w-4 h-4 text-blue-600 rounded">
                        <span class="text-sm font-medium text-gray-700">Activa</span>
                    </label>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-3">Opciones de Respuesta</label>
                    <p class="text-sm text-gray-500 mb-3">Selecciona la respuesta correcta</p>
                    <div class="space-y-3">
                        @for (int i = 0; i < Model.Opciones.Count; i++)
                        {
                            <div class="flex items-center gap-3">
                                <input type="radio" name="CorrectoIndex" value="@i" 
                                       @(Model.CorrectoIndex == i ? "checked" : "")
                                       class="w-4 h-4 text-blue-600">
                                <input asp-for="Opciones[i].Respuesta" placeholder="Opción @(i + 1)" 
                                       class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                            </div>
                        }
                    </div>
                </div>

                <div class="flex gap-3 pt-4">
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg transition-colors">
                        Guardar Pregunta
                    </button>
                    <a href="/Admin/Preguntas" class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-6 py-2 rounded-lg transition-colors">
                        Cancelar
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>
